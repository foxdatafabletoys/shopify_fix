# Copy this file to ".env" and fill in the values.
# Do not commit .env anywhere — it contains a private API token.

# Your store's myshopify subdomain. If your admin URL is
#   https://telemachus-foxfable.myshopify.com/admin
# then SHOPIFY_STORE=telemachus-foxfable
SHOPIFY_STORE=
SHOPIFY_CLIENT_ID=
# Admin API access token from your custom app. Starts with "shpat_..."
SHOPIFY_TOKEN=
# Leave blank to auto-detect your store's primary location.
# If you override it, use a Shopify location GID; numeric IDs also work and are normalized internally.
# Canonical example: SHOPIFY_LOCATION=gid://shopify/Location/12345678901
SHOPIFY_LOCATION=


